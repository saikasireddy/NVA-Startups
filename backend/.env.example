# Core paths
DOCX_PATH=../Mentoring Startups GuideF.docx
FAISS_INDEX_DIR=./faiss_index

# CORS
CORS_ALLOW_ALL=true
FRONTEND_URL=http://localhost:3000

# Ollama / model runtime
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=220
OLLAMA_NUM_CTX=2048

# Retrieval / memory window
RETRIEVER_K=4
MAX_HISTORY_TURNS=3
